# Container benchmark profile for comparing against Redis under a similar setup.

BENCH_TARGET=redis
BENCH_THREADS=2
BENCH_WARMUP_OPS=100000
BENCH_MEASURED_OPS=500000
BENCH_KEY_SPACE=100000
BENCH_LIST_KEY_SPACE=10000
BENCH_VALUE_SIZE=32
BENCH_BLOCKING_PAIRS=2
BENCH_BLOCKING_OPS=2000

BENCH_REDIS_HOST=zappydb-redis
BENCH_REDIS_PORT=6379
BENCH_REDIS_FLUSH=true