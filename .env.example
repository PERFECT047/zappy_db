# ZappyDB Environment Configuration
# Copy this file to .env and customize values as needed

# Server port (default: 6379)
PORT=6379

# Thread pool size for concurrent clients (default: 4)
# Recommended: minimum - 2 * number of CPU cores
# Recommended: maximum - 4 * number of CPU cores
#THREAD_POOL_SIZE=4

# Concurrency strategy: THREAD_POOL / NIO_EVENT_LOOP(default)
# Currently supported: THREAD_POOL / NIO_EVENT_LOOP
CONCURRENCY_STRATEGY=NIO_EVENT_LOOP