# ZappyDB Environment Configuration
# Copy this file to .env and customize values as needed

# Server port (default: 6379)
PORT=6379

# Thread pool size for concurrent clients (default: 4)
# Recommended: 2 * number of CPU cores
THREAD_POOL_SIZE=4

# Concurrency strategy: THREAD_POOL (default)
# Currently supported: THREAD_POOL
CONCURRENCY_STRATEGY=THREAD_POOL